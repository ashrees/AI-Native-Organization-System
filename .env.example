# Copy to .env in the project root and fill in values.
# cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────
# Postgres connection string (Neon, local Postgres, etc.)
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Server ─────────────────────────────────────────────────────────────
PORT=3000
# POSTGRES_SCHEMA=public
# PG_POOL_MAX=10
# PG_CONNECTION_TIMEOUT_MS=10000
# SSE_MAX_CLIENTS=200

# ── LLM provider (optional — stub AI runs without keys) ─────────────────
# Force provider: google | openai | deepseek | ollama
# LLM_PROVIDER=google

# Google Gemini (either key works)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek (OpenAI-compatible API — https://platform.deepseek.com/api_keys)
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MODEL=deepseek-reasoner

# Ollama — recommended: Cloud free tier (no local GPU)
# LLM_PROVIDER=ollama
# Create API key: https://ollama.com/settings/keys
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com
# Default models (direct API; comma-separated fallbacks):
# OLLAMA_MODEL=gpt-oss:120b,nemotron-3-super,gpt-oss:20b
# OLLAMA_TIMEOUT_MS=180000
# OLLAMA_NUM_PREDICT=8192
#
# Ollama local (optional): run `ollama serve` on localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
#
# Ollama local app routing to Cloud (`ollama signin` + `ollama pull gpt-oss:120b-cloud`):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gpt-oss:120b-cloud,nemotron-3-super:cloud,gpt-oss:20b-cloud

# LLM retries and agent timeouts
# LLM_MAX_RETRIES=5
# LLM_RETRY_DELAY_MS=3000
# AGENT_LLM_TIMEOUT_MS=25000
# AGENT_STEP_RETRIES=3
# AGENT_STEP_RETRY_DELAY_MS=1500

# Project AI — status checks and agent delegation
# PROJECT_AI_DEBOUNCE_MS=15000
# PROJECT_AI_POLL_INTERVAL_MS=300000
# OPS_MONITOR_STREAM_HOURS=3

# Help chat context limits
# HELP_CHAT_EVENT_LIMIT=250
# HELP_CHAT_ACTIVITY_LIMIT=40

# Mock worker NPCs (background simulation)
# MOCK_WORKER_ENABLED=true
# MOCK_WORKER_INTERVAL_MS=45000
# MOCK_WORKER_BATCH_SIZE=4
# MOCK_WORKER_REQUEST_CHANCE=0.28
# MOCK_WORKER_LEAVE_CHANCE=0.05
# MOCK_WORKER_LEAVE_COOLDOWN_MS=900000
# MOCK_WORKER_MAX_ON_LEAVE_COUNT=3
# MOCK_WORKER_MAX_ON_LEAVE_FRACTION=0.15
# MOCK_WORKER_HR_LEAVE_APPROVE_CHANCE=0.4

# Personal HR + preferences stored in Postgres (user_preferences table, people.hr_person_id)

# ── Frontends (optional, set when building) ─────────────────────────────
# Leadership View (client/) — API base URL (default: /api via Vite proxy in dev)
# VITE_API_URL=http://localhost:3000
# Link to Worker Portal (client header)
# VITE_WORKER_PORTAL_URL=http://localhost:5174
# VITE_MONITOR_PORTAL_URL=http://localhost:5175

# Worker Portal (worker/) — API + link back to leadership
# VITE_API_URL=http://localhost:3000
# VITE_LEADERSHIP_URL=http://localhost:5173
