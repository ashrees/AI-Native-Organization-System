# Copy to .env in the project root and fill in values.
# cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────
# Postgres connection string (Neon, local Postgres, etc.)
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Server ─────────────────────────────────────────────────────────────
PORT=3000
# POSTGRES_SCHEMA=public

# ── LLM provider (optional — stub AI runs without keys) ─────────────────
# Force provider: google | openai | ollama
# LLM_PROVIDER=google

# Google Gemini (either key works)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TIMEOUT_MS=120000
# OLLAMA_NUM_PREDICT=2048

# LLM retries and agent timeouts
# LLM_MAX_RETRIES=5
# LLM_RETRY_DELAY_MS=3000
# AGENT_LLM_TIMEOUT_MS=25000
# AGENT_STEP_RETRIES=3
# AGENT_STEP_RETRY_DELAY_MS=1500

# ── Client (optional) ───────────────────────────────────────────────────
# Override API base URL (default: /api via Vite proxy in dev)
# VITE_API_URL=http://localhost:3000
